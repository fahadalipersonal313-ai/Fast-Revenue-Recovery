# Revenue Recovery Desk — environment configuration
# Copy this file to ".env" and adjust. Every value is OPTIONAL: the app runs
# fully without any of these set, using built-in rules and message templates.

# --- REQUIRED before onboarding real clients --------------------------------
# Encrypts each tenant's email credentials at rest (src/crypto.py). Without
# this set, a hardcoded development key is used and a warning banner is shown
# in the app — fine for local testing, NOT safe for real client data.
# Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
APP_SECRET_KEY=

# --- Optional AI message improvement -------------------------------------
# Turn the AI helper on. Leave false (or omit) to run in reliable rules mode.
AI_ENABLED=false
# "gemini" (default, free tier via Google AI Studio) or "anthropic" (paid).
AI_PROVIDER=gemini
# API key for whichever provider you chose (only read from the environment,
# never stored). For Gemini, get a free key at https://aistudio.google.com/apikey
# For Anthropic, use your Anthropic Console key. AI_API_KEY works for either.
AI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
# Model id to use. Leave blank to use the provider's sensible default
# (gemini-2.5-flash-lite for Gemini — larger free-tier daily quota;
#  claude-opus-4-8 for Anthropic).
AI_MODEL=

# --- Optional email drafting -----------------------------------------------
# When enabled, approving an item saves a DRAFT (never sends) into your own
# email Drafts folder via IMAP. Works with Gmail using an App Password
# (Google Account -> Security -> App passwords); requires 2FA to be on.
#
# In multi-tenant/SaaS mode, each signed-up client enters THEIR OWN email +
# app password in the app's Settings page (encrypted with APP_SECRET_KEY
# above, stored in their own isolated tenant database) — these env vars are
# only a fallback used when no per-tenant credentials are saved yet (e.g. the
# original single-user/local setup).
EMAIL_DRAFT_ENABLED=false
EMAIL_ADDRESS=
EMAIL_APP_PASSWORD=
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_DRAFTS_FOLDER=[Gmail]/Drafts

# --- Optional password-reset email (app-level SMTP) ------------------------
# Used to SEND the 6-digit "Forgot password" code. This is app-level (shared,
# pre-login) — separate from the per-tenant IMAP draft credentials above.
# Leave unset to disable email reset (users can still change their password
# from Settings -> Account while logged in). For Gmail use an App Password and
# host smtp.gmail.com with STARTTLS on port 587 (or SSL on 465).
RRD_SMTP_HOST=
RRD_SMTP_PORT=587
RRD_SMTP_USER=
RRD_SMTP_PASSWORD=
RRD_SMTP_FROM=
RRD_SMTP_STARTTLS=true
RRD_SMTP_SSL=false
RRD_APP_NAME=Revenue Recovery Desk

# --- Business defaults (can also be changed in the Settings page) --------
# Invoices at or above this amount always require human approval.
HIGH_VALUE_THRESHOLD=5000
# Time of day (24h HH:MM) for the optional scheduled daily analysis.
DAILY_ANALYSIS_TIME=08:00
